{
    "family": "ai-detector",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "2048",
    "memory": "8192",
    "executionRoleArn": "arn:aws:iam::020212777583:role/ai-detector-execution-role",
    "taskRoleArn": "arn:aws:iam::020212777583:role/ai-detector-task-role",
    "containerDefinitions": [
        {
            "name": "ai-detector",
            "image": "020212777583.dkr.ecr.us-east-1.amazonaws.com/ai-detector:latest",
            "portMappings": [
                {
                    "containerPort": 8000,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {"name": "ENVIRONMENT", "value": "production"},
                {"name": "DEBUG", "value": "false"},
                {"name": "AWS_DEFAULT_REGION", "value": "us-east-1"},
                {"name": "ENVIRONMENT", "value": "production"},
                {"name": "LLM_PROVIDER", "value": "google"},
                {"name": "LLM_MODEL_GOOGLE", "value": "gemma-4-31b-it"},
                {"name": "LLM_SEND_IMAGE_LOCALLY", "value": "true"}
            ],
            "secrets": [
                {
                    "name": "API_KEYS",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:020212777583:secret:ai-detector/api-keys-1CVOat"
                },
                {
                    "name": "GOOGLE_AI_API_KEY",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:020212777583:secret:ai-detector/google-ai-api-key-yxumKL"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/ai-detector",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "essential": true
        }
    ]
}